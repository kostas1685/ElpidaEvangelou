{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "evangeloulaw.gr" }],
      "destination": "https://www.evangeloulaw.gr/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/arthra/:slug", "destination": "/arthra/artro/index.html" }
  ],
  "functions": {
    "api/contact.js": { "maxDuration": 10 }
  }
}
